{
  "name": "logistics-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Logistics Management Platform - Deployable on Vercel",
  "scripts": {
    "dev": "concurrently \"pnpm --filter logistics-api dev\" \"pnpm --filter logistics-web dev\"",
    "dev:api": "pnpm --filter logistics-api dev",
    "dev:web": "pnpm --filter logistics-web dev",
    "build": "pnpm --filter logistics-web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "prisma generate --schema=./api/prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=./api/prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=./api/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./api/prisma/schema.prisma",
    "db:seed": "pnpm --filter logistics-api db:seed",
    "vercel-build": "prisma generate --schema=./api/prisma/schema.prisma && prisma migrate deploy --schema=./api/prisma/schema.prisma && pnpm build",
    "postinstall": "prisma generate --schema=./api/prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "concurrently": "^8.2.2",
    "prisma": "^5.8.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@prisma/client": "^5.8.1"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@8.15.0"
}
