# Vercel Environment Variables
# Add these in your Vercel dashboard under Project Settings > Environment Variables

# Database (Vercel Postgres or external)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Redis (Upstash Redis recommended for Vercel)
REDIS_URL="rediss://default:token@your-redis-instance.upstash.io:6379"

# JWT Secret (generate with: openssl rand -base64 64)
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long"

# CORS Origin (your frontend URL)
CORS_ORIGIN="https://your-app.vercel.app"

# Optional
BCRYPT_ROUNDS="12"
NODE_ENV="production"
